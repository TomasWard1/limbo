# Local end-to-end testing — WhatsApp + Kapso + LiteLLM.
#
# Copy to `.env.local` and fill in every value. This file is gitignored;
# scripts/bootstrap-local-whatsapp.sh reads it and materializes the three
# generated artifacts (litellm-config.yaml, config/litellm.env, config/.env)
# under /tmp/limbo-local-whatsapp.
#
# Each value should live in 1Password long-term; `.env.local` is just the
# single place you edit to wire the local stack. Do not commit.

# ── User-provided secrets ──────────────────────────────────────────────

# Anthropic API key (real API key, not an OAuth token — must start with sk-ant-api).
# 1P reference: Development/limbo/anthropic-api
ANTHROPIC_API_KEY=

# Kapso Cloud API key (X-API-Key header for the Kapso REST API).
# 1P reference: Development/limbo/kapso-api
KAPSO_API_KEY=

# Kapso phone-number id (from the Kapso dashboard → WhatsApp numbers).
# Not a secret, but unique per deployment.
KAPSO_PHONE_NUMBER_ID=

# NVIDIA NIM API key (OPTIONAL — unlocks GLM-5.1 fallback in LiteLLM).
# Free tier: 40 req/min, credit-capped, latency erratic. Dev/eval only.
# If unset, Sonnet still works; the fallback route will no-op on error.
# Starts with `nvapi-`. Get one at build.nvidia.com.
# 1P reference: Development/limbo/nvidia-testing (UUID kj4tujq2kc7rqbxb6dsc5xuzg4)
NVIDIA_API_KEY=

# ── Optional overrides ─────────────────────────────────────────────────

# Image tag used by docker-compose.local-whatsapp.yml.
# Default: limbo:local-whatsapp (built on first run from the current worktree).
# LIMBO_IMAGE=limbo:local-whatsapp

# Alternate state dir (default /tmp/limbo-local-whatsapp).
# STATE_DIR=/tmp/limbo-local-whatsapp

# Your timezone for scheduling / reminders. Default: America/Argentina/Buenos_Aires.
# USER_TIMEZONE=America/Argentina/Buenos_Aires

# Primary model override. Local dev defaults to GLM-5.1 (free via NVIDIA NIM).
# Uncomment to pin Sonnet (real token spend) or another supported model.
# LiteLLM fallbacks still cover GLM→Sonnet on error either way.
# MODEL_PROVIDER=anthropic
# MODEL_NAME=claude-sonnet-4-6
