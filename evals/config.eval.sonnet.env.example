# Sonnet-via-LiteLLM eval environment — used by docker-compose.eval-sonnet.yml.
#
# Secrets (GATEWAY_TOKEN, LLM_API_KEY=<litellm virtual key>, GROQ_API_KEY,
# BRAVE_API_KEY, TELEGRAM_BOT_TOKEN) come from ~/.limbo-dev/eval-tokens.env
# + the sonnet bootstrap step, loaded via additional `env_file` entries in
# the compose file. This file holds only non-secret eval config.
#
# MODEL_PROVIDER/MODEL_NAME + LITELLM_* are the knobs that flip regen-openclaw-config.sh
# into the litellm-proxied mode (see scripts/regen-openclaw-config.sh, LITELLM block).
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-6
RUNTIME_REASONING_EFFORT=medium
LIMBO_PORT=18790
LIMBO_EVAL=true
AUTH_MODE=api-key
LITELLM_ENABLED=true
LITELLM_URL=http://litellm-eval:4000
TELEGRAM_ENABLED=false
VOICE_ENABLED=false
WEB_SEARCH_ENABLED=true
GOOGLE_CALENDAR_ENABLED=true
USER_TIMEZONE=America/Argentina/Buenos_Aires
