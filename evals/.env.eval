# Eval environment — used by docker-compose.eval.yml
# Tokens (LLM_API_KEY, GROQ_API_KEY, GATEWAY_TOKEN, TELEGRAM_BOT_TOKEN, ...) are
# loaded from ~/.limbo-dev/eval-tokens.env, mounted as a second `env_file` entry
# in evals/docker-compose.eval.yml. This file holds only non-secret eval config.
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4
RUNTIME_REASONING_EFFORT=medium
LIMBO_PORT=18790
LIMBO_EVAL=true
TELEGRAM_ENABLED=true
VOICE_ENABLED=true
WEB_SEARCH_ENABLED=false
AUTH_MODE=subscription
USER_TIMEZONE=America/Argentina/Buenos_Aires
