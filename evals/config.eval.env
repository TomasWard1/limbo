CLI_LANGUAGE=es
AUTH_MODE=subscription
MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4
RUNTIME_REASONING_EFFORT=medium
LIMBO_PORT=18790
TELEGRAM_ENABLED=true
VOICE_ENABLED=true
WEB_SEARCH_ENABLED=false
# Enables the Google Calendar MCP tools (calendar_read, calendar_create).
# The eval run uses a mock gws binary installed by hooks.js, so no real
# Google credentials are required — see evals/fixtures/gws/.
GOOGLE_CALENDAR_ENABLED=true
