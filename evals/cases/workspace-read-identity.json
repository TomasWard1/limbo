{
  "name": "workspace-read-identity",
  "description": "Agent describes itself accurately when asked what it is",
  "input": "Qué sos? Contame sobre vos",
  "assertions": [
    { "type": "response_matches", "pattern": "(?i)(limbo|vault|asistente|memoria|personal)" }
  ],
  "runs": 1,
  "pass_threshold": 1.0,
  "tags": ["workspace"],
  "difficulty": "easy"
}
